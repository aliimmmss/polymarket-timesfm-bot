# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=polymarket_bot
DB_USER=bot_user
DB_PASSWORD=your_secure_password_here

# TimesFM / HuggingFace
HF_TOKEN=your_huggingface_token_here

# Polymarket Configuration
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_WALLET_PRIVATE_KEY=your_wallet_private_key_here  # For live trading only
POLYMARKET_WALLET_ADDRESS=your_wallet_address_here

# External APIs (Optional)
NEWS_API_KEY=your_newsapi_key_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
GDELT_API_KEY=your_gdelt_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Trading Parameters (Can be overridden in config files)
INITIAL_CAPITAL=1000.0
PAPER_TRADING=true
MAX_DAILY_LOSS=0.05
MAX_POSITION_SIZE=0.10
MAX_POSITION_CORRELATION=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/polymarket_bot.log

# Development
DEBUG=false
TEST_MODE=false

# Note: Never commit actual values to version control!
# Copy this file to .env and fill in your actual values.