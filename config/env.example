# Polymarket Trading Bot Configuration
# Copy to config.env and fill in your values

# === WALLET & NETWORK ===
PRIVATE_KEY=
FUNDER_ADDRESS=
POLYGON_RPC_URL=https://polygon-rpc.com
SIGNATURE_TYPE=2  # 1=POLY_GNOSIS_SAFE, 2=EOA (recommended)

# === TRADING SAFETY ===
# IMPORTANT: Keep DRY_RUN=true for testing!
DRY_RUN=true
AUTO_TRADE=false
TRADE_AMOUNT_USDC=5.0
MAX_ORDER_SIZE_USDC=10.0
DAILY_LOSS_LIMIT_USDC=20.0

# === STRATEGY SIGNALS ===
# Signal A: Token Price Disagreement + CVD confirms
SIGNAL_A_GAP_THRESHOLD=20.0
SIGNAL_A_MAX_PRICE=0.55
SIGNAL_A_MIN_TIME=300  # 5 minutes remaining

# Signal B: Late Window Convergence
SIGNAL_B_GAP_THRESHOLD=50.0
SIGNAL_B_MAX_PRICE=0.95
SIGNAL_B_MAX_TIME=180  # 3 minutes remaining

# Signal C: Strong Momentum + Mispricing
SIGNAL_C_CVD_THRESHOLD=50.0
SIGNAL_C_OBI_THRESHOLD=0.30
SIGNAL_C_MAX_PRICE=0.50
SIGNAL_C_MIN_TIME=300

# === STOP LOSS ===
STOP_LOSS_GAP=10.0
STOP_LOSS_PROB_PCT=0.15  # 15% drop from entry
STOP_LOSS_CHECK_INTERVAL=5.0
MIN_HOLD_TIME=30.0

# === MONITOR ===
CLOB_POLL_INTERVAL=10.0
TOKEN_PRICE_POLL_INTERVAL=5.0
MONITOR_INTERVAL=5.0

# === TELEGRAM (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === POLYMARKET BUILDER API (for auto-redeem) ===
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
